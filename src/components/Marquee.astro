---
const items = ['Sandía Ice', 'Mango Tropical', 'Blueberry', 'Fresa Crema', 'Uva Helada', 'Limón Mojito', 'Melocotón', 'Menta Polar'];
---

<section class="overflow-hidden border-y border-cream/10 bg-ink-2 py-7">
  <div class="marquee items-center gap-8" data-speed="60" data-dir="left">
    {items.map((item) => (
      <div class="flex items-center gap-8">
        <span class="font-display text-3xl font-extrabold uppercase tracking-tight text-cream/90 md:text-5xl">{item}</span>
        <span class="text-2xl text-berry md:text-4xl">✦</span>
      </div>
    ))}
  </div>
</section>
