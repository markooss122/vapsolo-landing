---
const links = [
  { href: '#sabores', label: 'Sabores' },
  { href: '#productos', label: 'Productos' },
  { href: '#como-funciona', label: 'Cómo funciona' },
  { href: '#faq', label: 'FAQ' },
];
---

<header id="site-nav" class="fixed inset-x-0 top-0 z-50">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="#hero" class="flex items-center gap-2.5" aria-label="Inicio">
      <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-brand font-display text-lg font-extrabold text-white">V</span>
      <span class="font-display text-xl font-extrabold tracking-tight text-cream">Vapsolo</span>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {links.map((l) => (
        <li>
          <a href={l.href} class="group relative text-sm font-medium text-cream/75 transition-colors hover:text-cream">
            {l.label}
            <span class="absolute -bottom-1 left-0 h-px w-0 bg-gradient-brand transition-all duration-300 group-hover:w-full"></span>
          </a>
        </li>
      ))}
    </ul>

    <a
      href="#productos"
      data-magnetic
      class="rounded-full bg-cream px-5 py-2.5 text-sm font-semibold text-ink transition-colors hover:bg-white"
    >
      Comprar
    </a>
  </nav>
</header>
