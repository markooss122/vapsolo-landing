---
const products = [
  { name: 'Vapsolo Mini', puffs: '600 caladas', price: '6,95', emoji: '🍓', perks: ['Ultra compacto', 'Ideal para probar', 'Carga única'], featured: false },
  { name: 'Vapsolo Pro', puffs: '4000 caladas', price: '12,95', emoji: '🥭', perks: ['Carga USB-C', 'Indicador de batería', 'El más vendido'], featured: true },
  { name: 'Vapsolo Max', puffs: '8000 caladas', price: '17,95', emoji: '🍉', perks: ['Doble depósito', 'Hasta 2 semanas', 'Sabor extra intenso'], featured: false },
];
---

<section id="productos" class="relative overflow-hidden py-24 md:py-32">
  <div class="mesh"></div>
  <div class="relative z-10 mx-auto max-w-6xl px-6">
  <div class="mb-16 max-w-2xl">
    <p class="mb-4 font-display text-sm font-semibold uppercase tracking-[0.3em] text-berry" data-reveal>/ Elige el tuyo</p>
    <h2 class="display-xl text-5xl md:text-7xl" data-split>Tres tamaños.<br /><span class="text-gradient">Una calidad.</span></h2>
  </div>

  <div class="grid items-stretch gap-6 lg:grid-cols-3" data-reveal-group>
    {products.map((p) => (
      <div
        data-reveal-item
        data-tilt
        class={`relative flex flex-col rounded-3xl border p-8 [transform-style:preserve-3d] ${p.featured ? 'border-berry/40 bg-gradient-to-b from-grape/15 to-ink-2' : 'border-cream/10 bg-ink-2'}`}
      >
        {p.featured && (
          <span class="absolute -top-3 left-8 rounded-full bg-gradient-brand px-4 py-1 text-xs font-bold text-white">
            MÁS VENDIDO
          </span>
        )}
        <div class="text-5xl">{p.emoji}</div>
        <h3 class="mt-4 font-display text-2xl font-bold text-cream">{p.name}</h3>
        <p class="text-cream/45">{p.puffs}</p>

        <div class="mt-5 flex items-end gap-1">
          <span class="display-xl text-4xl text-cream">{p.price}€</span>
          <span class="mb-1 text-sm text-cream/40">/ unidad</span>
        </div>

        <ul class="mt-6 flex-1 space-y-2.5">
          {p.perks.map((perk) => (
            <li class="flex items-center gap-2 text-cream/70">
              <span class="flex h-5 w-5 items-center justify-center rounded-full bg-mint/20 text-xs text-mint">✓</span>
              {perk}
            </li>
          ))}
        </ul>

        <a
          href="#"
          class={`mt-7 rounded-full px-6 py-3.5 text-center font-semibold transition hover:scale-[1.02] ${p.featured ? 'bg-gradient-brand text-white' : 'border border-cream/15 text-cream hover:bg-cream/5'}`}
        >
          Añadir al carrito
        </a>
      </div>
    ))}
  </div>

  <p class="mt-8 text-center text-sm text-cream/40" data-reveal>
    Envío gratis a partir de 30€ · Pago seguro · Entrega en 24/48h
  </p>
  </div>
</section>
