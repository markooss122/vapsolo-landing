---
// Gate de verificación de edad (+18). Aparece tras el preloader.
---

<div
  id="age-gate"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-ink/95 px-4 backdrop-blur-md"
  aria-modal="true"
  role="dialog"
  aria-labelledby="age-gate-title"
>
  <div class="w-full max-w-md rounded-[2rem] border border-cream/10 bg-ink-2 p-8 text-center shadow-2xl">
    <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-brand font-display text-2xl font-extrabold text-white">
      +18
    </div>
    <h2 id="age-gate-title" class="font-display text-2xl font-extrabold text-cream">
      ¿Eres mayor de edad?
    </h2>
    <p class="mt-3 text-sm leading-relaxed text-cream/60">
      Este sitio vende productos con nicotina y está reservado a
      <strong class="text-cream">mayores de 18 años</strong>. Confirma tu edad para continuar.
    </p>

    <div class="mt-6 flex flex-col gap-3 sm:flex-row">
      <button
        id="age-yes"
        class="flex-1 rounded-full bg-gradient-brand px-6 py-3 font-semibold text-white transition hover:scale-[1.03]"
      >
        Sí, soy mayor de 18
      </button>
      <a
        id="age-no"
        href="https://www.google.com"
        class="flex-1 rounded-full border border-cream/15 px-6 py-3 font-semibold text-cream/70 transition hover:bg-cream/5"
      >
        No
      </a>
    </div>

    <p class="mt-5 text-xs text-cream/30">
      Al entrar aceptas la política de privacidad y el uso de cookies.
    </p>
  </div>
</div>

<script>
  const KEY = 'vapsolo_age_ok';
  const gate = document.getElementById('age-gate');

  function show() {
    gate?.classList.remove('hidden');
    gate?.classList.add('flex');
    (window as any).__lenis?.stop();
    document.body.style.overflow = 'hidden';
  }
  function hide() {
    gate?.classList.add('hidden');
    gate?.classList.remove('flex');
    (window as any).__lenis?.start();
    document.body.style.overflow = '';
  }

  if (localStorage.getItem(KEY) !== 'true') show();

  document.getElementById('age-yes')?.addEventListener('click', () => {
    localStorage.setItem(KEY, 'true');
    hide();
  });
</script>
