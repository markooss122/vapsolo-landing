---
interface Props {
  class?: string;
  iconClass?: string;
  textClass?: string;
  showText?: boolean;
}
const {
  class: cls = '',
  iconClass = 'h-9 w-9',
  textClass = 'text-2xl',
  showText = true,
} = Astro.props;

// id único para el degradado (evita colisiones con varios logos en la página)
const uid = 've-' + Math.random().toString(36).slice(2, 8);
---

<span class={`inline-flex items-center gap-3 ${cls}`}>
  <svg class={iconClass} viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <linearGradient id={uid} x1="14" y1="6" x2="50" y2="58" gradientUnits="userSpaceOnUse">
        <stop stop-color="#8b5cf6" />
        <stop offset="0.5" stop-color="#ff4d8d" />
        <stop offset="1" stop-color="#ffb020" />
      </linearGradient>
    </defs>
    <!-- Hilo de vapor en espiral -->
    <path d="M32 21 C 26 16 30 11 33 11 C 37 11 38 6 33.5 4" stroke={`url(#${uid})`} stroke-width="2.6" stroke-linecap="round" />
    <!-- Gota de esencia -->
    <path d="M32 19 C 34 30 45 33 45 43.5 a13 13 0 1 1 -26 0 C 19 33 30 30 32 19 Z" fill={`url(#${uid})`} />
    <!-- Reflejo -->
    <circle cx="26.5" cy="45" r="4.3" fill="#fff" opacity="0.28" />
  </svg>

  {showText && (
    <span class={`font-serif leading-none tracking-tight text-cream ${textClass}`} style="font-weight:600">
      Vap <span class="italic text-gradient">Esssence</span>
    </span>
  )}
</span>
