---
const flavors = [
  { img: 'watermelonice', name: 'Sandía Ice', notes: 'Dulce y refrescante' },
  { img: 'strawberrywatermelon', name: 'Fresa & Sandía', notes: 'Jugoso veraniego' },
  { img: 'grapeburst', name: 'Uva Explosiva', notes: 'Intenso y dulce' },
  { img: 'blueberrysourraspberry', name: 'Arándano & Frambuesa', notes: 'Ácido y fresco' },
  { img: 'strawberrybanana', name: 'Fresa & Plátano', notes: 'Suave y cremoso' },
  { img: 'strawberrykiwi', name: 'Fresa & Kiwi', notes: 'Dulce con punto ácido' },
  { img: 'peachmangopineapple', name: 'Melocotón, Mango & Piña', notes: 'Tropical' },
  { img: 'kiwipassionfruitguava', name: 'Kiwi, Maracuyá & Guayaba', notes: 'Exótico' },
  { img: 'lemonlime', name: 'Limón & Lima', notes: 'Cítrico vibrante' },
  { img: 'cherrycola', name: 'Cherry Cola', notes: 'Refresco clásico' },
  { img: 'cherrylemon', name: 'Cereza & Limón', notes: 'Dulce y cítrico' },
  { img: 'mixedberry', name: 'Frutos Rojos', notes: 'Mezcla de bayas' },
  { img: 'peachberry', name: 'Melocotón & Bayas', notes: 'Dulce y jugoso' },
  { img: 'blackicedragonfruitstrawberry', name: 'Pitaya, Fresa & Ice', notes: 'Frescor frutal' },
];
---

<section id="sabores" data-horizontal class="relative bg-ink">
  <div class="flex h-screen items-center overflow-hidden">
    <div data-htrack class="flex items-center gap-6 px-[8vw] will-change-transform">
      <!-- Panel de intro -->
      <div class="flex w-[80vw] shrink-0 flex-col justify-center md:w-[40vw]">
        <p class="mb-4 font-display text-sm font-semibold uppercase tracking-[0.3em] text-berry">/ La colección</p>
        <h2 class="display-xl text-6xl md:text-8xl">Nuestros<br /><span class="text-gradient">sabores</span></h2>
        <p class="mt-6 max-w-sm text-lg text-cream/55">14 sabores seleccionados. Desliza para recorrerlos y encuentra el tuyo.</p>
        <span class="mt-8 inline-flex items-center gap-2 text-sm text-cream/40">Arrastra <span aria-hidden="true">→</span></span>
      </div>

      {flavors.map((f, i) => (
        <article data-tilt class="group relative flex h-[66vh] w-[74vw] shrink-0 flex-col overflow-hidden rounded-[2rem] border border-cream/10 bg-gradient-to-b from-ink-2 to-ink [transform-style:preserve-3d] sm:w-[42vw] md:w-[26vw]">
          <span class="absolute right-5 top-5 z-10 rounded-full bg-ink/50 px-2.5 py-1 text-xs font-medium text-white/80 backdrop-blur-sm">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div class="relative flex-1 overflow-hidden">
            <img
              src={`/products/${f.img}.png`}
              alt={`Vaper Vap Esssence — ${f.name}`}
              loading="lazy"
              class="absolute inset-0 h-full w-full object-contain p-4 transition-transform duration-700 ease-out group-hover:scale-[1.06]"
            />
          </div>
          <div class="border-t border-cream/10 p-5">
            <h3 class="font-display text-xl font-extrabold text-cream">{f.name}</h3>
            <p class="mt-0.5 text-sm text-cream/55">{f.notes}</p>
          </div>
        </article>
      ))}

      <!-- Panel de cierre -->
      <div class="flex w-[60vw] shrink-0 flex-col justify-center md:w-[28vw]">
        <h3 class="display-xl text-4xl md:text-5xl">Tu sabor<br /><span class="text-gradient">te espera</span></h3>
        <a href="#productos" data-magnetic class="mt-6 inline-block w-max rounded-full bg-cream px-7 py-3.5 font-semibold text-ink transition-colors hover:bg-white">
          Ver productos
        </a>
      </div>
    </div>
  </div>
</section>
