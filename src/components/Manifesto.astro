    <div class="relative hidden md:block" data-reveal>
      <div class="absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full bg-berry/30 blur-[80px]"></div>
      <img
        src="/products/watermelonice.png"
