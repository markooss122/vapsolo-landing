<section class="relative overflow-hidden py-32 md:py-44">
  <div class="mesh"></div>
  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-12 px-6 md:grid-cols-[1.5fr_1fr]">
    <div>
      <p class="mb-10 font-display text-sm font-semibold uppercase tracking-[0.3em] text-berry" data-reveal>
        / Nuestra filosofía
      </p>
      <p
        data-highlight
        class="font-display text-3xl font-semibold leading-[1.25] tracking-tight text-cream md:text-[2.7rem] md:leading-[1.2]"
