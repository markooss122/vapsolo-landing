---
const features = [
  { icon: '🔋', title: 'Batería todo el día', text: 'Hasta 8000 caladas con carga USB-C rápida. Nunca te deja tirado.' },
  { icon: '🍓', title: 'Sabor de verdad', text: 'Mezclas intensas que notas desde la primera calada hasta la última.' },
  { icon: '✨', title: 'Listo para usar', text: 'Sin recargas ni botones. Lo sacas del paquete y disfrutas.' },
  { icon: '🚚', title: 'Envío 24/48h', text: 'En casa en uno o dos días, con embalaje discreto y seguro.' },
  { icon: '🛡️', title: 'Calidad certificada', text: 'Conforme a la normativa TPD de la Unión Europea.' },
  { icon: '💸', title: 'Precio justo', text: 'Packs y suscripción con descuento. Más sabor por menos.' },
];
---

<section id="ventajas" class="relative overflow-hidden py-24 md:py-32">
  <div class="mesh"></div>
  <div class="relative z-10 mx-auto max-w-6xl px-6">
  <div class="mb-16 max-w-2xl">
    <p class="mb-4 font-display text-sm font-semibold uppercase tracking-[0.3em] text-berry" data-reveal>/ Por qué Vapsolo</p>
    <h2 class="display-xl text-5xl md:text-7xl" data-split>Todo lo que pides.<br /><span class="text-gradient">Nada que sobre.</span></h2>
  </div>

  <div class="grid gap-px overflow-hidden rounded-3xl border border-cream/10 bg-cream/10 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
    {features.map((f) => (
      <div data-reveal-item class="group bg-ink p-8 transition-colors duration-300 hover:bg-ink-2">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-brand text-2xl transition-transform duration-300 group-hover:scale-110">
          {f.icon}
        </div>
        <h3 class="mt-6 font-display text-xl font-bold text-cream">{f.title}</h3>
        <p class="mt-2 leading-relaxed text-cream/55">{f.text}</p>
      </div>
    ))}
  </div>
  </div>
</section>
